# .env.example
# ------------
# This file is safe to commit to GitHub. It shows what variables are needed
# without exposing real values.
#
# SETUP INSTRUCTIONS:
#   1. Copy this file:   cp .env.example .env
#   2. Fill in your real TMDB API key in .env
#   3. Never commit .env to GitHub (it's in .gitignore)
#
# GET A FREE TMDB API KEY:
#   1. Create an account at https://www.themoviedb.org/
#   2. Go to Settings → API → Request an API Key (choose Developer)
#   3. Copy the "API Key (v3 auth)" value

TMDB_API_KEY=your_tmdb_api_key_here
